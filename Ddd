function Library:Notification(config)
    local notifTitle = config.Title or "Notification"
    local notifText = config.Text or "This is a notification"
    local duration = config.Duration or 3
    
    local player = game.Players.LocalPlayer
    
    -- Find or create notification container
    local notifGui = player.PlayerGui:FindFirstChild("NotificationGui")
    if not notifGui then
        notifGui = Instance.new("ScreenGui")
        notifGui.Name = "NotificationGui"
        notifGui.ResetOnSpawn = false
        notifGui.IgnoreGuiInset = true
        notifGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        notifGui.Parent = player.PlayerGui
    end
    
    local notif = Instance.new("Frame")
    notif.Name = "Notification"
    notif.Size = UDim2.new(0, 300, 0, 0)
    notif.Position = UDim2.new(1, -320, 1, -20)
    notif.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    notif.BorderSizePixel = 0
    notif.ClipsDescendants = true
    notif.Parent = notifGui
    
    local notifCorner = Instance.new("UICorner")
    notifCorner.CornerRadius = UDim.new(0, 10)
    notifCorner.Parent = notif
    
    local notifStroke = Instance.new("UIStroke")
    notifStroke.Color = Color3.fromRGB(255, 255, 255)
    notifStroke.Thickness = 1
    notifStroke.Transparency = 0.9
    notifStroke.Parent = notif
    
    local titleLabel = Instance.new("TextLabel")
    titleLabel.Size = UDim2.new(1, -20, 0, 25)
    titleLabel.Position = UDim2.new(0, 10, 0, 5)
    titleLabel.BackgroundTransparency = 1
    titleLabel.Text = notifTitle
    titleLabel.Font = Enum.Font.GothamBold
    titleLabel.TextSize = 14
    titleLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    titleLabel.TextXAlignment = Enum.TextXAlignment.Left
    titleLabel.Parent = notif
    
    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1, -20, 1, -35)
    textLabel.Position = UDim2.new(0, 10, 0, 30)
    textLabel.BackgroundTransparency = 1
    textLabel.Text = notifText
    textLabel.Font = Enum.Font.Gotham
    textLabel.TextSize = 12
    textLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    textLabel.TextXAlignment = Enum.TextXAlignment.Left
    textLabel.TextYAlignment = Enum.TextYAlignment.Top
    textLabel.TextWrapped = true
    textLabel.Parent = notif
    
    -- Calculate height based on text
    local textHeight = textLabel.TextBounds.Y
    local totalHeight = math.max(60, textHeight + 40)
    
    -- Animate in
    TweenService:Create(notif, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, 300, 0, totalHeight)
    }):Play()
    
    -- Move up existing notifications
    for _, child in ipairs(notifGui:GetChildren()) do
        if child ~= notif and child:IsA("Frame") then
            local currentPos = child.Position
            TweenService:Create(child, TweenInfo.new(0.3), {
                Position = UDim2.new(currentPos.X.Scale, currentPos.X.Offset, currentPos.Y.Scale, currentPos.Y.Offset - totalHeight - 10)
            }):Play()
        end
    end
    
    -- Auto-dismiss
    task.delay(duration, function()
        TweenService:Create(notif, TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In), {
            Size = UDim2.new(0, 300, 0, 0),
            Position = UDim2.new(1, -320, notif.Position.Y.Scale, notif.Position.Y.Offset)
        }):Play()
        
        task.wait(0.3)
        notif:Destroy()
    end)
end

return Library
