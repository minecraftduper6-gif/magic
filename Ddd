    sidebarFixBottom.Position = UDim2.new(1, -12, 1, -12)
    sidebarFixBottom.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    sidebarFixBottom.BorderSizePixel = 0
    sidebarFixBottom.Parent = sidebar
    
    -- Tab Container (Scrollable)
    local tabContainer = Instance.new("ScrollingFrame")
    tabContainer.Name = "TabContainer"
    tabContainer.Size = UDim2.new(1, -10, 1, -10)
    tabContainer.Position = UDim2.new(0, 5, 0, 5)
    tabContainer.BackgroundTransparency = 1
    tabContainer.BorderSizePixel = 0
    tabContainer.ScrollBarThickness = 3
    tabContainer.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
    tabContainer.CanvasSize = UDim2.new(0, 0, 0, 0)
    tabContainer.Parent = sidebar
    
    local tabLayout = Instance.new("UIListLayout")
    tabLayout.SortOrder = Enum.SortOrder.LayoutOrder
    tabLayout.Padding = UDim.new(0, 8)
    tabLayout.Parent = tabContainer
    
    tabLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        tabContainer.CanvasSize = UDim2.new(0, 0, 0, tabLayout.AbsoluteContentSize.Y + 10)
    end)
    
    -- Content Area
    local contentArea = Instance.new("Frame")
    contentArea.Name = "ContentArea"
    contentArea.Size = UDim2.new(1, -160, 1, -60)
    contentArea.Position = UDim2.new(0, 155, 0, 55)
    contentArea.BackgroundTransparency = 1
    contentArea.BorderSizePixel = 0
    contentArea.Parent = mainContainer
    
    -- Dragging functionality
    local dragging = false
    local dragInput, dragStart, startPos
    
    topBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true
            dragStart = input.Position
            startPos = mainContainer.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
            local delta = input.Position - dragStart
            mainContainer.Position = UDim2.new(
                startPos.X.Scale,
                startPos.X.Offset + delta.X,
                startPos.Y.Scale,
                startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Sound
    local clickSound = Instance.new("Sound")
    clickSound.SoundId = "rbxassetid://6895079853"
    clickSound.Volume = 0.3
    clickSound.Parent = gui
    
    -- Window Object
    local Window = {
        Gui = gui,
        MainContainer = mainContainer,
        TabContainer = tabContainer,
        ContentArea = contentArea,
        ClickSound = clickSound,
        Tabs = {},
        CurrentTab = nil,
        TabCount = 0
    }
    
    -- Entrance animation
    mainContainer.Size = UDim2.new(0, 0, 0, 0)
    TweenService:Create(mainContainer, TweenInfo.new(0.5, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
        Size = originalSize
    }):Play()
    
    function Window:CreateTab(tabName)
        Window.TabCount = Window.TabCount + 1
        
        -- Tab Button
        local tabButton = Instance.new("TextButton")
        tabButton.Name = tabName
        tabButton.Size = UDim2.new(1, 0, 0, 35)
        tabButton.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
        tabButton.Text = tabName
        tabButton.Font = Enum.Font.GothamBold
        tabButton.TextSize = 13
        tabButton.TextColor3 = Color3.fromRGB(180, 180, 180)
        tabButton.BorderSizePixel = 0
        tabButton.AutoButtonColor = false
        tabButton.LayoutOrder = Window.TabCount
        tabButton.Parent = Window.TabContainer
        
        local tabCorner = Instance.new("UICorner")
        tabCorner.CornerRadius = UDim.new(0, 6)
        tabCorner.Parent = tabButton
        
        -- Tab Content (Scrollable)
        local tabContent = Instance.new("ScrollingFrame")
        tabContent.Name = tabName .. "Content"
        tabContent.Size = UDim2.new(1, 0, 1, 0)
        tabContent.BackgroundTransparency = 1
        tabContent.BorderSizePixel = 0
        tabContent.ScrollBarThickness = 4
        tabContent.ScrollBarImageColor3 = Color3.fromRGB(255, 255, 255)
        tabContent.CanvasSize = UDim2.new(0, 0, 0, 0)
        tabContent.Visible = false
        tabContent.Parent = Window.ContentArea
        
        local contentLayout = Instance.new("UIListLayout")
        contentLayout.SortOrder = Enum.SortOrder.LayoutOrder
        contentLayout.Padding = UDim.new(0, 10)
        contentLayout.Parent = tabContent
        
        local contentPadding = Instance.new("UIPadding")
        contentPadding.PaddingLeft = UDim.new(0, 5)
        contentPadding.PaddingRight = UDim.new(0, 5)
        contentPadding.PaddingTop = UDim.new(0, 5)
        contentPadding.Parent = tabContent
        
        contentLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
            tabContent.CanvasSize = UDim2.new(0, 0, 0, contentLayout.AbsoluteContentSize.Y + 15)
        end)
        
        -- Tab Object
        local Tab = {
            Button = tabButton,
            Content = tabContent,
            ElementCount = 0
        }
        
        -- Tab Click Handler
        tabButton.MouseButton1Click:Connect(function()
            Window.ClickSound:Play()
            
            -- Hide all tabs
            for _, tab in pairs(Window.Tabs) do
                tab.Content.Visible = false
                tab.Button.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
                tab.Button.TextColor3 = Color3.fromRGB(180, 180, 180)
            end
            
            -- Show this tab
            tabContent.Visible = true
            tabButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            tabButton.TextColor3 = Color3.fromRGB(0, 0, 0)
            Window.CurrentTab = Tab
        end)
        
        -- Hover effects
        tabButton.MouseEnter:Connect(function()
            if Window.CurrentTab ~= Tab then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(25, 25, 25)
                }):Play()
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if Window.CurrentTab ~= Tab then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(18, 18, 18)
                }):Play()
            end
        end)
        
        Window.Tabs[tabName] = Tab
        
        -- Auto-select first tab
        if Window.TabCount == 1 then
            tabButton.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            tabButton.TextColor3 = Color3.fromRGB(0, 0, 0)
            tabContent.Visible = true
            Window.CurrentTab = Tab
        end
        
        -- ============================
        -- TAB COMPONENTS
        -- ============================
        
        function Tab:AddButton(config)
            Tab.ElementCount = Tab.ElementCount + 1
            
            local buttonText = config.Text or "Button"
            local callback = config.Callback or function() end
            
            local button = Instance.new("TextButton")
            button.Name = "Button"
            button.Size = UDim2.new(1, -10, 0, 40)
            button.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
            button.Text = buttonText
            button.Font = Enum.Font.GothamBold
            button.TextSize = 14
            button.TextColor3 = Color3.fromRGB(0, 0, 0)
            button.BorderSizePixel = 0
            button.AutoButtonColor = false
            button.LayoutOrder = Tab.ElementCount
            button.Parent = tabContent
            
            local buttonCorner = Instance.new("UICorner")
            buttonCorner.CornerRadius = UDim.new(0, 8)
            buttonCorner.Parent = button
            
            button.MouseEnter:Connect(function()
                TweenService:Create(button, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(200, 200, 200)
                }):Play()
            end)
            
            button.MouseLeave:Connect(function()
                TweenService:Create(button, TweenInfo.new(0.2), {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                }):Play()
            end)
            
            button.MouseButton1Click:Connect(function()
                Window.ClickSound:Play()
                TweenService:Create(button, TweenInfo.new(0.1), {
                    BackgroundColor3 = Color3.fromRGB(150, 150, 150)
                }):Play()
                task.wait(0.1)
                TweenService:Create(button, TweenInfo.new(0.1), {
                    BackgroundColor3 = Color3.fromRGB(255, 255, 255)
                }):Play()
                callback()
            end)
            
            return button
        end
        
